                        ]
                    }
                ],
                "typeProperties": {
                    "items": {
                        "value": "@activity('ft_origin_ADVWDB').output.value",
                        "type": "Expression"
                    },
                    "isSequential": true,
                    "activities": [
                        {
                            "name": "if_tabla_ADVWDB",
                            "description": "SalesOrderDetail=incremental, Product=total",
                            "type": "IfCondition",
                            "dependsOn": [],
                            "typeProperties": {
                                "expression": {
                                    "value": "@equals(item().nombre_tabla, 'SalesOrderDetail')",
                                    "type": "Expression"
                                },
                                "ifFalseActivities": [
                                    {
                                        "name": "ca_silver_ADVWDB_Product",
