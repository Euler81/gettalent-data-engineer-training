                "type": "Filter",
                "dependsOn": [
                    {
                        "activity": "lk_config_origin_bronze_silver",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    }
                ],
                "typeProperties": {
                    "items": {
                        "value": "@activity('lk_config_origin_bronze_silver').output.value",
                        "type": "Expression"
                    },
                    "condition": {
                        "value": "@and(equals(item().origen, 'ADVWDB'), equals(item().activo, 1))",
                        "type": "Expression"
                    }
                }
            },
            {
